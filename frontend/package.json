{
  "name": "flash-boot-ui",
  "version": "1.1.1",
  "private": true,

  "main": "electron/main.js",

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "electron-builder",
    "electron": "electron ."
  },

  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },

  "devDependencies": {
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },

  "build": {
    "appId": "com.flashboot.tool",
    "productName": "Flash Boot Tool",

    "directories": {
      "output": "release"
    },

    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],

    "win": {
      "target": "nsis"
    }
  }
}
