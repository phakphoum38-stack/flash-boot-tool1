{
  "name": "flash-boot-ui",
  "version": "1.1.2",
  "main": "electron/main.js",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.flashboot.tool",
    "productName": "Flash Boot Tool",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis"
    }
  }
}
