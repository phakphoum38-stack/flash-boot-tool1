{
  "name": "flash-boot-tool",
  "version": "1.0.0",
  "description": "Flash Boot Tool (Etcher-level USB writer)",
  "author": "phakphum",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "dev:electron": "electron .",
    "dist": "npm run build:frontend && electron-builder --win --x64"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "28.3.3",
    "electron-builder": "^24.13.3",
    "vite": "^5.0.0",
    "wait-on": "^9.0.5",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "build": {
    "appId": "com.flashboot.tool",
    "productName": "Flash Boot Tool",
    "directories": {
      "output": "release"
    },
    "files": [
      "frontend/dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico",
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "phakphoum38-stack",
      "repo": "flash-boot-tool1"
    }
  }
}
