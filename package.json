{
  "name": "flash-boot-ui",
  "version": "1.0.0",
  "description": "USB Flash Boot Tool",
  "author": "phakphum",
  "main": "electron/main.js",

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },

  "devDependencies": {
    "vite": "^5.0.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-updater": "^6.1.7"
  },

  "build": {
    "appId": "com.flashboot.tool",
    "productName": "Flash Boot Tool",

    "directories": {
      "output": "release"
    },

    "files": [
      "dist/**/*",
      "electron/**/*"
    ],

    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend"
      }
    ],

    "publish": {
      "provider": "github",
      "owner": "phakphoum38-stack",
      "repo": "flash-boot-tool1"
    },

    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  }
}
